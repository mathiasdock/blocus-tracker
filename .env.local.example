# Copy this file to .env.local and fill in your Supabase project values.
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# URL de ton site (utilisée pour le lien de reset de mot de passe)
# En local : http://localhost:3000
# En production : https://ton-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Active un faux backend local pour coder quand Supabase prod est indisponible.
# Ne pas définir cette variable sur Vercel/prod.
NEXT_PUBLIC_OFFLINE_DEV=false
