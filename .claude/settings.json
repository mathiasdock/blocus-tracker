{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git restore --staged:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git commit:*)",
      "Bash(git remote -v:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npx next build:*)",
      "Bash(npx next lint:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(wc:*)",
      "Bash(pwd)",
      "Bash(echo:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore --:*)",
      "Bash(cat .env*)",
      "Bash(cat *.env.local)",
      "Bash(type .env*)",
      "Bash(npm publish:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase db reset:*)",
      "Bash(psql:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy --prod:*)",
      "Read(./.env.local)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env.local)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env.local)",
      "Write(./.env)",
      "Write(./.env.*)"
    ],
    "defaultMode": "default"
  }
}
